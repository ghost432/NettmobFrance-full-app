{
  "name": "NettMobFrance",
  "short_name": "NettMob",
  "description": "Plateforme de mise en relation pour professionnels du nettoyage - Notifications persistantes",
  "start_url": "/login?mode=pwa",
  "display": "standalone",
  "background_color": "#ffffff",
  "theme_color": "#a31a4d",
  "orientation": "portrait-primary",
  "icons": [
    {
      "src": "/favicon-1.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "/favicon-1.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ],
  "categories": [
    "business",
    "productivity",
    "social"
  ],
  "lang": "fr-FR",
  "dir": "ltr",
  "scope": "/",
  "prefer_related_applications": false,
  "_comment": "=== CONFIGURATION EXPERT NOTIFICATIONS PERSISTANTES ===",
  "gcm_sender_id": "1074853867939",
  "firebase_messaging_sw": "/firebase-messaging-sw.js",
  "permissions": [
    "notifications",
    "push",
    "background-sync",
    "background-fetch"
  ],
  "protocol_handlers": [
    {
      "protocol": "web+nettmob",
      "url": "/?handler=%s"
    }
  ],
  "shortcuts": [
    {
      "name": "Nouvelles missions",
      "short_name": "Missions",
      "description": "Voir les nouvelles missions disponibles",
      "url": "/automob/missions",
      "icons": [
        {
          "src": "/favicon-1.png",
          "sizes": "192x192"
        }
      ]
    },
    {
      "name": "Mes candidatures",
      "short_name": "Candidatures",
      "description": "Gérer mes candidatures",
      "url": "/automob/applications",
      "icons": [
        {
          "src": "/favicon-1.png",
          "sizes": "192x192"
        }
      ]
    },
    {
      "name": "Publier mission",
      "short_name": "Publier",
      "description": "Créer une nouvelle mission",
      "url": "/client/publish-mission",
      "icons": [
        {
          "src": "/favicon-1.png",
          "sizes": "192x192"
        }
      ]
    }
  ],
  "capture_links": "new-client",
  "launch_handler": {
    "client_mode": [
      "focus-existing",
      "auto"
    ]
  },
  "handle_links": "preferred",
  "edge_side_panel": {
    "preferred_width": 400
  },
  "display_override": [
    "window-controls-overlay",
    "standalone",
    "minimal-ui"
  ],
  "file_handlers": [],
  "share_target": {
    "action": "/share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  }
}