console.log('🚀 NettmobFrance Service Worker - Mode Expert Ultra');
console.log('📱 Notifications persistantes : App fermée ✅ | Navigateur fermé ✅ | Utilisateur déconnecté ✅');
console.log('🎯 Mode Ultra : Réception garantie même si automob déconnecté de son compte');

// Configuration Firebase
const firebaseConfig = {
  apiKey: "AIzaSyDSwL0wNQuS6KwWCPO-ufVjC_NObFTMHis",
  authDomain: "nettmobfrance-92e4a.firebaseapp.com",
  databaseURL: "https://nettmobfrance-92e4a-default-rtdb.firebaseio.com",
  projectId: "nettmobfrance-92e4a",
  storageBucket: "nettmobfrance-92e4a.appspot.com",
  messagingSenderId: "1074853867939",
  appId: "1:1074853867939:web:35ab84f541ea15a0fcaa16",
